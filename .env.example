# shellcheck disable=SC2148,SC2034

# Devo app/server environment.
# Copy to .env for local development. Do not commit real secrets.

# Required in production. Use a long random value.
AUTH_SECRET=replace-with-a-long-random-secret

# Public base URL for auth callbacks and cookies.
# Local default dev server:
SITE_URL=http://127.0.0.1:5173

# Directory for local DB, task files, run files, and installed task packages.
# Defaults to .devo under the app working directory.
# DEVO_DATA_DIR=.devo

# Task runtime. auto uses the runtime running the Devo app: bun when Devo runs
# under Bun, node when Devo runs under Node. Set to bun or node to force one.
DEVO_TASK_RUNTIME=auto

# Task runner pool size.
DEVO_WORKERS=2

# Maximum time a task process can run before it is killed.
DEVO_TASK_TIMEOUT_MS=30000

# Maximum combined stdout/stderr captured from a task before it is killed.
DEVO_TASK_MAX_OUTPUT_BYTES=1048576

# Maximum bytes stored for any single task log line.
DEVO_TASK_MAX_LOG_LINE_BYTES=16384

# Maximum time an editor terminal command can run before it is killed.
DEVO_TERMINAL_TIMEOUT_MS=120000

# How often the local scheduler checks cron tasks.
DEVO_SCHEDULER_INTERVAL_MS=15000

# Run history cleanup. Set either value to 0 to disable that cleanup rule.
DEVO_RUN_RETENTION_DAYS=30
DEVO_MAX_RUNS_PER_TASK=100

# Task-specific secrets/env vars are edited per task in the task editor .env file,
# not in this app-level file.
